      "type": "object",
      "required": ["success", "instance_name"],
      "properties": {
        "success": {
          "type": "boolean"
        },
        "instance_name": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
